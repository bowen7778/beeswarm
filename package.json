{
  "name": "beeswarm-kernel",
  "version": "1.0.0",
  "description": "Model Context Protocol Server",
  "author": "Orchestrator Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bowen7778/mcp-orchestrator"
  },
  "type": "module",
  "main": "build/dist/cli.cjs",
  "scripts": {
    "build:server": "tsup src/startup/cli.ts",
    "build:ui": "node -e \"const fs=require('fs'); fs.rmSync('build/ui', {recursive:true, force:true}); fs.mkdirSync('build/ui', {recursive:true}); fs.cpSync('ui', 'build/ui', {recursive:true});\"",
    "build": "pnpm run build:server && pnpm run build:ui",
    "typecheck": "npx tsc -p tsconfig.json --noEmit --pretty false",
    "start": "node build/dist/cli.cjs",
    "dev": "node scripts/release.mjs --sync-only && node scripts/dev.mjs",
    "release": "node scripts/release.mjs --sync-only && node scripts/release.mjs",
    "release:push": "node scripts/release.mjs --sync-only && node scripts/release.mjs --push",
    "version:sync": "node scripts/release.mjs --sync-only",
    "lint:atomic": "node scripts/lint-atomic.mjs",
    "lint:api:contract": "node scripts/lint-api-contract.mjs",
    "lint:ui": "pnpm run lint:ui:contract && pnpm run lint:ui:i18n",
    "lint:ui:contract": "node scripts/lint-ui-contract.mjs",
    "lint:ui:i18n": "node scripts/lint-ui-i18n.mjs",
    "check:full": "node scripts/full-health-check.mjs",
    "clean": "node scripts/clean.mjs"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@modelcontextprotocol/sdk": "^1.5.0",
    "express": "^4.21.2",
    "inversify": "^6.2.2",
    "open": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "systray2": "^2.1.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@swc/core": "^1.15.21",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "git-push": "^0.1.1",
    "isomorphic-git": "^1.37.4",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vite": "^8.0.3"
  }
}
